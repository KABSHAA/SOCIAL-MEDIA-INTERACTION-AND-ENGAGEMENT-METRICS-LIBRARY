#ifndef SOCIALMEDIA_H
#define SOCIALMEDIA_H

#include <iostream>
#include <string>
using namespace std;

class EngagementPost {
private:
    string content;
    int likes, comments, shares;

public:
    // Constructors (Function Overloading)
    EngagementPost() : content("Empty"), likes(0), comments(0), shares(0) {}

    EngagementPost(string c, int l, int cm, int s)
        : content(c), likes(l), comments(cm), shares(s) {}

    EngagementPost(const EngagementPost &p)
        : content(p.content), likes(p.likes),
          comments(p.comments), shares(p.shares) {}

    // Function Overloading
    void update() {
        likes++;
    }

    void update(int l, int cm, int s) {
        likes += l;
        comments += cm;
        shares += s;
    }

    void update(string newContent) {
        content = newContent;
    }

    int engagement() const {
        return likes + (3 * comments) + (5 * shares); // slightly unique
    }

    string getCategory() const {
        if (engagement() > 80) return "Viral";
        else if (engagement() > 40) return "Trending";
        else return "Normal";
    }

    // Operator Overloading
    EngagementPost operator+(const EngagementPost &p) {
        return EngagementPost(
            content + " & " + p.content,
            likes + p.likes,
            comments + p.comments,
            shares + p.shares
        );
    }

    EngagementPost operator-(const EngagementPost &p) {
        return EngagementPost(
            "Difference",
            likes - p.likes,
            comments - p.comments,
            shares - p.shares
        );
    }

    EngagementPost operator*(int factor) {
        return EngagementPost(
            content,
            likes * factor,
            comments * factor,
            shares * factor
        );
    }

    bool operator==(const EngagementPost &p) {
        return engagement() == p.engagement();
    }

    bool operator<(const EngagementPost &p) {
        return engagement() < p.engagement();
    }

    friend ostream& operator<<(ostream &out, const EngagementPost &p) {
        out << "\nPost: " << p.content
            << "\nLikes: " << p.likes
            << "\nComments: " << p.comments
            << "\nShares: " << p.shares
            << "\nEngagement Score: " << p.engagement()
            << "\nCategory: " << p.getCategory() << endl;
        return out;
    }
};

#endif
#include "../include/SocialMedia.h"

int main() {

    EngagementPost p1("Travel Vlog", 15, 6, 3);
    EngagementPost p2("Tech Review", 25, 10, 5);
    EngagementPost p3(p1);

    // Function overloading
    p1.update();
    p2.update(5, 2, 1);
    p3.update("Updated Travel Post");

    cout << "=== Posts ===\n";
    cout << p1 << p2 << p3;

    // Operator overloading
    EngagementPost combined = p1 + p2;
    EngagementPost diff = p1 - p2;
    EngagementPost boosted = p1 * 2;

    cout << "\n=== Combined ===" << combined;
    cout << "\n=== Difference ===" << diff;
    cout << "\n=== Boosted ===" << boosted;

    // Comparison
    if (p1 == p2)
        cout << "\nEqual Engagement\n";
    else
        cout << "\nDifferent Engagement\n";

    if (p1 < p2)
        cout << "p1 is less popular\n";

    return 0;
}
